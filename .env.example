# voice-agent-studio — environment reference (P3-7)
#
# Copy this file to .env (gitignored) and fill in what you need. Only
# GEMINI_API_KEY is required to boot backend.integrated_app: every other
# key below gates one optional, lazily-imported real integration — leave it
# unset and that feature falls back to an in-memory/mock implementation so
# the app still runs end-to-end (D9 swap posture). Load into your shell
# before running the backend or tests:
#
#     set -a && source .env && set +a

# --- Required ---

# The Gemini model wrapper (backend/wrapper_impl). Either key works; the
# wrapper checks GEMINI_API_KEY first, then GOOGLE_API_KEY.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# --- Model wrapper tuning (optional) ---

# Per-tier model-id overrides — all default to gemini-3.5-flash in config.py.
# Preview model names churn — verify in the AI Studio console before setting.
# GEMINI_MODEL_FRONTIER=gemini-3.1-pro
# GEMINI_MODEL_FAST=gemini-3.5-flash
# GEMINI_MODEL_VOICE=gemini-3.1-flash-live
# GEMINI_MODEL_VOICE_LIVE=gemini-3.1-flash-live-preview   # preview STT (P3-4)
# GEMINI_MODEL_TTS=gemini-2.5-flash-preview-tts           # preview TTS (reads text aloud)
# GEMINI_TTS_VOICE=Kore                                    # prebuilt TTS voice

# Vertex AI swap (production access path instead of an AI Studio API key).
# GEMINI_USE_VERTEX=1
# GOOGLE_CLOUD_PROJECT=your-project
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Security / screening (backend/security) ---
# Unset: the screener reports "unavailable" and the fail-open/fail-closed
# policy in config.py applies (never a silent "clean"). Model Armor lives in
# the same GCP project as Vertex, so GOOGLE_CLOUD_PROJECT above is shared.
# MODEL_ARMOR_API_KEY=
# MODEL_ARMOR_LOCATION=us-central1
# MODEL_ARMOR_TEMPLATE=
# MODEL_ARMOR_ENDPOINT=
# SCREENING_TIMEOUT_SECONDS=2.5

# --- Persistence (backend/integration/persistence.py) ---
# DURABLE BY DEFAULT: with nothing set below, agents/campaigns/events/accounts are
# stored in SQLite at ./.data/vas.db (zero-config, survives a restart). Set
# DATABASE_URL to a libpq DSN to use Postgres instead — tables are auto-created at
# boot (idempotent CREATE TABLE IF NOT EXISTS), so an empty database just works.
# Set VAS_IN_MEMORY=true for a fully ephemeral boot (tests/CI only).
# SQLITE_DB_PATH=./.data/vas.db
# DATABASE_URL=postgresql://user:password@localhost:5432/voice_agent_studio
# VAS_IN_MEMORY=true
#
# FREE HOSTED POSTGRES (Supabase) — full walkthrough in docs/supabase-setup.md.
# Use the "Session pooler" connection string (Supabase dashboard -> Connect):
# it is IPv4-friendly AND supports LISTEN/NOTIFY, which the events bus needs.
# Do NOT use the Transaction pooler (port 6543) — it breaks LISTEN/NOTIFY.
# Requires `psycopg[binary]` (already in requirements.txt). Append ?sslmode=require.
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# --- Accounts / sign-in (backend/auth) ---
# Real accounts: signing in creates a `backend.auth` user + a session cookie
# (replaces the old fixed dev user everywhere — config_gate, orchestrator, events,
# tool connections all scope to whoever is signed in). Login uses the SAME Google
# OAuth client as the Calendar/Gmail tool-connect flow above, but a DIFFERENT
# callback path — register this ADDITIONAL redirect URI on that client (Google
# Cloud Console -> APIs & Services -> Credentials -> your OAuth client):
#   http://localhost:8000/api/auth/google/callback
# Unset GOOGLE_OAUTH_CLIENT_ID/SECRET: login still works end-to-end against a
# no-network fake identity (dev only — don't rely on this past localhost).
# COOKIE_SECURE=false   # set true once served over https (production)
#
# AUTH_MODE controls whether login is REQUIRED:
#   login (default) — must sign in; the login screen gates the app.
#   open            — demo posture: anonymous visitors share ONE public workspace
#                     (PUBLIC_USER_ID, default "public-user"); no login screen. Google
#                     sign-in stays available so anyone who wants their OWN isolated
#                     space (and real tool connections) can still sign in.
# AUTH_MODE=login
# PUBLIC_USER_ID=public-user

# --- Credential encryption (backend/tool_registry/credentials.py) ---
# Fernet key protecting connected-tool OAuth tokens at rest. Unset: a fresh
# ephemeral key is minted on boot (logged as a warning) — fine for dev, but
# stored tokens won't survive a restart. Generate a real one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TOOL_REGISTRY_ENC_KEY=

# --- Google Calendar OAuth (P3-1, backend/tool_registry/oauth.py) ---
# Unset: build_calendar_client() returns the in-repo MockCalendarClient. When set,
# the tenant must connect via the OAuth flow (no placeholder is seeded for a real
# calendar). Register this EXACT redirect URI in the OAuth client:
#   http://localhost:8000/api/oauth/callback
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# The backend's callback base + where the browser bounces back to in the app.
# OAUTH_REDIRECT_BASE_URL=http://localhost:8000
# APP_BASE_URL=http://localhost:5173

# --- Resend email (P3-2, backend/integration/resend_email.py) ---
# Unset: build_email_client() returns the in-repo MockEmailClient. RESEND_FROM_EMAIL
# is REQUIRED when RESEND_API_KEY is set; onboarding@resend.dev works with no domain
# verification for testing. RESEND_DEV_RECIPIENT (optional) forces all sends to one
# inbox so you can see them.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev
# RESEND_DEV_RECIPIENT=

# --- Retell outbound phone (P3-3, backend/voice_runtime/transports.py) ---
# Unset: the transport factory returns MockVoiceTransport (scripted lead, no
# telephony account needed to run a campaign end-to-end). A REAL call also needs your
# backend reachable from the internet (Retell streams media to RETELL_WS_HOST) — use
# a tunnel (ngrok) or a deployed host; localhost will not work.
# RETELL_API_KEY=
# RETELL_FROM_NUMBER=
# RETELL_TRANSFER_NUMBER=
# RETELL_WS_HOST=your-public-host.ngrok.app
# RETELL_WS_PORT=443

# --- Twilio outbound phone, Live-native (backend/live_agent/phone_transport.py) ---
# When ALL four are set, campaign calls run the SAME audio-native Gemini Live agent as
# the browser preview over a real phone (Twilio Media Streams <-> Live). Unset: the
# scripted-mock text dialer runs so a campaign still completes in dev. No extra pip
# deps — the outbound call is placed over the existing httpx (no Twilio SDK). A real
# call needs the backend reachable from the internet so Twilio can connect its media
# stream: run `ngrok http 8000` and put the wss URL in PUBLIC_WSS_BASE (localhost will
# not work). Trial Twilio accounts can only call VERIFIED numbers.
# TWILIO_ACCOUNT_SID=AC...            # Console dashboard (starts with AC)
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1...            # your Twilio voice number, E.164
# PUBLIC_WSS_BASE=wss://<subdomain>.ngrok-free.app   # your public wss base (ngrok)
